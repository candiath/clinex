{
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.29",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jest": "^30.0.3",
    "jiti": "^2.6.1",
    "mongoose": "^8.15.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.49.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --clear src/app.ts",
    "test": "jest",
    "test:watch": "cls && jest --watch",
    "test:integration": "jest --testPathPatterns=tests/integration",
    "test:integration:watch": "jest --testPathPatterns=tests/integration --watch",
    "test:unit": "jest --testPathPatterns=domain",
    "test:all": "jest --coverage",
    "coverage": "jest --coverage",
    "docker:test:up": "docker-compose -f docker-compose.test.yml up -d",
    "docker:test:down": "docker-compose -f docker-compose.test.yml down -v",
    "docker:test:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "lint": "eslint"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "env-var": "^7.5.0",
    "express": "^5.1.0",
    "mysql2": "^3.14.2",
    "zod": "^4.1.13"
  }
}
